{
    // Plugin identifiers are globally unique and only contain A-Za-z0-9_-
    "id": "fiserv-govern-cicd",

    // It is highly recommended to use Semantic Versioning
    "version": "1.0.0",

    // Meta data for display purposes:
    "meta": {
        // label: name of the plugin as displayed, should be short
        "label": "Fiserv - GitHub Bundle Scanning",

        // description: longer string to help end users understand what this plugin does
        "description": "Publish Dataiku DSS bundles to GitHub and retrieve CI/security scan results as a report for governance workflows.",

        "author": "smazzei",

        "provider": "smazzei",

        // icon: must be one of the FontAwesome 5.15.4 icons, complete list here at https://fontawesome.com/v5/docs/
        "icon": "fas fa-shield-alt",

        // recipesCategory: optional, can be one of 'visual', 'code', 'genai' or 'other'
        // defines the category of the plugin in the right panel
        "recipesCategory": "other",

        // List of tags for filtering the list of plugins
        "tags": ["Governance", "CI/CD", "GitHub", "Security"],

        // URL where the user can learn more about the plugin
        "url": "",

        "licenseInfo": "Apache Software License"
    },
    "params": [
        {
            "name": "folders_to_skip",
            "label": "Folders to skip",
            "type": "STRINGS",
            "description": "Folders within the bundle to skip when pushing to github branch",
            "mandatory": true
        },
        {
            "name": "github_token",
            "label": "GitHub API Token",
            "type": "PASSWORD",
            "description": "GitHub API Token that can create/scan/run all commands against the repo/branch",
            "mandatory": true
        }
    ]
}
